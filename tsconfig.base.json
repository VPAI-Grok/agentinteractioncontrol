{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@aic/automation-core": ["packages/automation-core/src/index.ts"],
      "@aic/spec": ["packages/spec/src/index.ts"],
      "@aic/runtime": ["packages/runtime/src/index.ts"],
      "@aic/sdk-react": ["packages/sdk-react/src/index.tsx"],
      "@aic/plugin-next": ["packages/plugin-next/src/index.ts"],
      "@aic/plugin-vite": ["packages/plugin-vite/src/index.ts"],
      "@aic/devtools": ["packages/devtools/src/index.tsx"],
      "@aic/ai-bootstrap": ["packages/ai-bootstrap/src/index.ts"],
      "@aic/ai-bootstrap-http": ["packages/ai-bootstrap-http/src/index.ts"],
      "@aic/ai-bootstrap-openai": ["packages/ai-bootstrap-openai/src/index.ts"],
      "@aic/integrations-radix": ["packages/integrations-radix/src/index.ts"],
      "@aic/integrations-shadcn": ["packages/integrations-shadcn/src/index.tsx"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noEmitOnError": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  }
}
