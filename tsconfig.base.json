{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@aicorg/automation-core": ["packages/automation-core/src/index.ts"],
      "@aicorg/spec": ["packages/spec/src/index.ts"],
      "@aicorg/runtime": ["packages/runtime/src/index.ts"],
      "@aicorg/sdk-react": ["packages/sdk-react/src/index.tsx"],
      "@aicorg/plugin-next": ["packages/plugin-next/src/index.ts"],
      "@aicorg/plugin-vite": ["packages/plugin-vite/src/index.ts"],
      "@aicorg/devtools": ["packages/devtools/src/index.tsx"],
      "@aicorg/ai-bootstrap": ["packages/ai-bootstrap/src/index.ts"],
      "@aicorg/ai-bootstrap-http": ["packages/ai-bootstrap-http/src/index.ts"],
      "@aicorg/ai-bootstrap-openai": ["packages/ai-bootstrap-openai/src/index.ts"],
      "@aicorg/integrations-radix": ["packages/integrations-radix/src/index.ts"],
      "@aicorg/integrations-shadcn": ["packages/integrations-shadcn/src/index.tsx"],
      "@aicorg/mcp-server": ["packages/mcp-server/src/index.ts"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noEmitOnError": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  }
}
