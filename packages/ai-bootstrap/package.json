{
  "name": "@aic/ai-bootstrap",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "description": "Bootstrap prompt and review tooling for generating AIC drafts from captured pages.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VPAI-Grok/agentinteractioncontrol.git"
  },
  "homepage": "https://github.com/VPAI-Grok/agentinteractioncontrol",
  "bugs": {
    "url": "https://github.com/VPAI-Grok/agentinteractioncontrol/issues"
  },
  "keywords": ["aic", "agents", "bootstrap", "playwright"],
  "main": "./dist/ai-bootstrap/src/index.js",
  "types": "./dist/ai-bootstrap/src/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/ai-bootstrap/src/index.d.ts",
      "import": "./dist/ai-bootstrap/src/index.js",
      "default": "./dist/ai-bootstrap/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aic/spec": "workspace:*",
    "playwright": "^1.52.0"
  }
}
