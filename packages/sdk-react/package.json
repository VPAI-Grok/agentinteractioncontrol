{
  "name": "@aic/sdk-react",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "description": "React SDK for authoring AIC metadata and runtime registrations.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VPAI-Grok/AIC.git"
  },
  "homepage": "https://github.com/VPAI-Grok/AIC",
  "bugs": {
    "url": "https://github.com/VPAI-Grok/AIC/issues"
  },
  "keywords": ["aic", "agents", "react", "sdk"],
  "main": "./dist/sdk-react/src/index.js",
  "types": "./dist/sdk-react/src/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/sdk-react/src/index.d.ts",
      "import": "./dist/sdk-react/src/index.js",
      "default": "./dist/sdk-react/src/index.js"
    },
    "./client": {
      "types": "./dist/sdk-react/src/client.d.ts",
      "import": "./dist/sdk-react/src/client.js",
      "default": "./dist/sdk-react/src/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aic/runtime": "workspace:*",
    "@aic/spec": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
