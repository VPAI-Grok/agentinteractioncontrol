{
  "name": "@aicorg/integrations-shadcn",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "description": "shadcn/ui wrapper components for attaching AIC metadata.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/VPAI-Grok/AIC.git"
  },
  "homepage": "https://github.com/VPAI-Grok/AIC",
  "bugs": {
    "url": "https://github.com/VPAI-Grok/AIC/issues"
  },
  "keywords": [
    "aic",
    "agents",
    "shadcn",
    "react"
  ],
  "main": "./dist/integrations-shadcn/src/index.js",
  "types": "./dist/integrations-shadcn/src/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/integrations-shadcn/src/index.d.ts",
      "import": "./dist/integrations-shadcn/src/index.js",
      "default": "./dist/integrations-shadcn/src/index.js"
    },
    "./client": {
      "types": "./dist/integrations-shadcn/src/client.d.ts",
      "import": "./dist/integrations-shadcn/src/client.js",
      "default": "./dist/integrations-shadcn/src/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aicorg/sdk-react": "workspace:*",
    "@aicorg/spec": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
