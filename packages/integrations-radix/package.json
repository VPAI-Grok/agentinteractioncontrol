{
  "name": "@aic/integrations-radix",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "description": "Radix UI helper factories for attaching AIC metadata.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VPAI-Grok/agentinteractioncontrol.git"
  },
  "homepage": "https://github.com/VPAI-Grok/agentinteractioncontrol",
  "bugs": {
    "url": "https://github.com/VPAI-Grok/agentinteractioncontrol/issues"
  },
  "keywords": ["aic", "agents", "radix-ui", "react"],
  "main": "./dist/integrations-radix/src/index.js",
  "types": "./dist/integrations-radix/src/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/integrations-radix/src/index.d.ts",
      "import": "./dist/integrations-radix/src/index.js",
      "default": "./dist/integrations-radix/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aic/sdk-react": "workspace:*",
    "@aic/spec": "workspace:*"
  }
