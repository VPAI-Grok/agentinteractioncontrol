{
  "name": "@aicorg/plugin-vite",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "description": "Vite project scanning and artifact generation helpers for AIC.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/VPAI-Grok/AIC.git"
  },
  "homepage": "https://github.com/VPAI-Grok/AIC",
  "bugs": {
    "url": "https://github.com/VPAI-Grok/AIC/issues"
  },
  "keywords": [
    "aic",
    "agents",
    "vite",
    "plugin"
  ],
  "main": "./dist/plugin-vite/src/index.js",
  "types": "./dist/plugin-vite/src/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/plugin-vite/src/index.d.ts",
      "import": "./dist/plugin-vite/src/index.js",
      "default": "./dist/plugin-vite/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aicorg/automation-core": "workspace:*",
    "@aicorg/runtime": "workspace:*",
    "@aicorg/spec": "workspace:*",
    "typescript": "^5.8.2"
  }
}
