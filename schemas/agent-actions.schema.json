{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aic.dev/schemas/agent-actions.schema.json",
  "title": "AIC Semantic Actions Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec", "generated_at", "actions"],
  "properties": {
    "spec": {
      "const": "aic/0.1"
    },
    "manifest_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/actionContract"
      }
    }
  },
  "$defs": {
    "completionSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "enum": ["toast", "toast_or_navigation", "navigation", "dialog", "state_change", "custom"]
        },
        "value": {
          "type": "string"
        }
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supported"],
      "properties": {
        "supported": {
          "type": "boolean"
        },
        "max_items": {
          "type": "number"
        },
        "concurrency_limit": {
          "type": "number"
        },
        "mode": {
          "enum": ["all_or_nothing", "partial_success"]
        },
        "per_item_results": {
          "type": "boolean"
        }
      }
    },
    "actionContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "title",
        "target",
        "preconditions",
        "postconditions",
        "side_effects",
        "idempotent",
        "undoable",
        "estimated_latency_ms",
        "completion_signal",
        "failure_modes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "postconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "side_effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "idempotent": {
          "type": "boolean"
        },
        "undoable": {
          "type": "boolean"
        },
        "supports_dry_run": {
          "type": "boolean"
        },
        "estimated_latency_ms": {
          "type": "number"
        },
        "completion_signal": {
          "$ref": "#/$defs/completionSignal"
        },
        "preview_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "simulation_limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dry_run_action": {
          "type": "string"
        },
        "undo_action": {
          "type": "string"
        },
        "undo_window_seconds": {
          "type": "number"
        },
        "batch": {
          "$ref": "#/$defs/batch"
        }
      }
    }
  }
}
