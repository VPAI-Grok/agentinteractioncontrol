{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aic.dev/schemas/agent-workflows.schema.json",
  "title": "AIC Workflow Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec", "generated_at", "workflows"],
  "properties": {
    "spec": {
      "const": "aic/0.1"
    },
    "manifest_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflow"
      }
    }
  },
  "$defs": {
    "completionSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {
          "enum": ["toast", "toast_or_navigation", "navigation", "dialog", "state_change", "custom"]
        },
        "value": {
          "type": "string"
        }
      }
    },
    "workflowStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": ["element_action", "semantic_action"]
        },
        "action": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "requires_confirmation": {
          "type": "boolean"
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "entry_points", "steps"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "entry_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/workflowStep"
          }
        },
        "checkpoint_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_approval_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "retryable_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rollback_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "estimated_duration_ms": {
          "type": "number"
        },
        "completion_signal": {
          "$ref": "#/$defs/completionSignal"
        }
      }
    }
  }
}
